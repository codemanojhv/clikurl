{
  "manifest_version": 3,
  "name": "clikurl",
  "version": "1.0.0",
  "description": "Shorten URLs with clikurl.vercel.app",
  "permissions": ["activeTab", "clipboardWrite"],
  "host_permissions": ["https://clikurl.vercel.app/*", "http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html"
  }
}
